#!/bin/bash

CONFIG="/etc/vortigaunt/vortigaunt.conf"

if [ -f "$CONFIG" ]; then
    source "$CONFIG"
else
    echo "Configuración no encontrada"
    exit 1
fi

BASE="$VORTIGAUNT_HOME"

echo "=========================="
echo "   VORTIGAUNT TIMELINE"
echo "=========================="
echo

echo "HITOS:"
echo

cat "$BASE/milestones.log"

echo
echo "EXPERIENCIAS:"
echo

cat "$BASE/experiences.log"

echo
echo "EVENTOS RECIENTES:"
echo

tail -10 "$BASE/events.log"

echo
echo "=========================="
echo "    VORTIGAUNT ONLINE"
echo "=========================="
